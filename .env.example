# ──────────────────────────────────────────
# SubFlow — Environment Variables Template
# Copy this file to .env and fill in values
# ──────────────────────────────────────────

# ── Application ──────────────────────────
APP_ENV=development          # development | staging | production
APP_HOST=0.0.0.0
APP_PORT=8000
LOG_LEVEL=INFO               # DEBUG | INFO | WARNING | ERROR

# ── MySQL ─────────────────────────────────
MYSQL_HOST=db
MYSQL_PORT=3306
MYSQL_DATABASE=subflow
MYSQL_USER=subflow_user
MYSQL_PASSWORD=change_me_strong_password
MYSQL_ROOT_PASSWORD=change_me_root_password

# SQLAlchemy connection string (auto-assembled from above in code, or override here)
DATABASE_URL=mysql+pymysql://subflow_user:change_me_strong_password@db:3306/subflow

# ── LINE Bot ──────────────────────────────
LINE_CHANNEL_ACCESS_TOKEN=your_line_channel_access_token_here
LINE_CHANNEL_SECRET=your_line_channel_secret_here

# ── Google / Gmail API ────────────────────
# Path to your OAuth2 credentials JSON downloaded from Google Cloud Console
GOOGLE_CREDENTIALS_PATH=credentials.json
# Path where the OAuth token will be cached after first auth
GOOGLE_TOKEN_PATH=token.json
# If using a Service Account instead, set the path here
GOOGLE_SERVICE_ACCOUNT_JSON=service_account.json
# Gmail address to scrape receipts from
GMAIL_TARGET_ADDRESS=your_email@gmail.com

# ── Streamlit ─────────────────────────────
STREAMLIT_SERVER_PORT=8501
STREAMLIT_SERVER_ADDRESS=0.0.0.0
